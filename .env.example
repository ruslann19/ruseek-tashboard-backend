# Running mode
# Available running modes: dev, prod
RUNNING_MODE=selected_running_mode

# API keys
DEEPSEEK_API_KEY=your_api_key
ROUTERAI_API_KEY=your_api_key

# PostgreSQL
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_user_password

# DB connection
DB_NAME=your_db_name
DB_HOST=your_db_host
DB_PORT=your_db_port
DB_USER=your_postgres_user
DB_PASSWORD=your_postgres_user_password

# Frontend info (for CORS)
FRONTEND_URL=your_frontend_url

# Authentication
JWT_SECRET=your_secret_key
ALGORITHM=your_encoding_algorithm
CORRECT_PASSWORD=your_admin_password
SESSION_TIMEOUT_MINUTES=your_session_timeout_minutes
